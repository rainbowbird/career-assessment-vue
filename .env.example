# Career Assessment System - 环境变量配置
# 复制此文件为 .env 并修改为您自己的配置

# ============================================
# 数据库配置
# ============================================
# MySQL root 密码（必须设置强密码）
MYSQL_ROOT_PASSWORD=changeme_strong_password_123

# 应用数据库用户
DB_USER=appuser

# 应用数据库密码
DB_PASSWORD=changeme_app_password_456

# ============================================
# 安全配置
# ============================================
# JWT 密钥（用于生成认证令牌，请使用随机长字符串）
JWT_SECRET=your_random_secret_key_here_at_least_32_characters

# ============================================
# 应用配置
# ============================================
# 域名（用于生成链接，可选）
DOMAIN=localhost

# Web 端口（默认80，如果冲突可修改）
WEB_PORT=80

# API 端口（内部使用，不需要修改）
API_PORT=3000

# ============================================
# 可选配置
# ============================================
# 时区
TZ=Asia/Shanghai

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 数据库时区
MYSQL_TIME_ZONE=+08:00
